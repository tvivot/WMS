// Prisma — WMS Grupal. Base MySQL/MariaDB (Hostinger). NO PostgreSQL.
//
// Reglas de modularidad (CLAUDE.md):
//  - core_* es el núcleo transversal (lo usan todos los módulos).
//  - dev_* es propiedad del módulo Devoluciones.
//  - Relaciones DENTRO de un módulo: FK de Prisma.
//  - Relaciones hacia el núcleo (cliente, usuario, producto, transportista) y
//    hacia OTROS módulos (ubicaciones): se guardan por ID/código SIN FK dura,
//    se resuelven en código por servicios/puertos. Así una migración de un
//    módulo no rompe a otro, y la ubicación pasa por UbicacionResolverPort.

generator client {
  provider = "prisma-client-js"
  // Motor "binary" (proceso aparte): evita el panic "timer has gone away" del
  // engine nativo Node-API en el shared hosting de Hostinger.
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
//  CORE — núcleo transversal
// ===========================================================================

model Pais {
  id        Int      @id @default(autoincrement())
  codigoIso String   @unique @map("codigo_iso") @db.VarChar(3)
  nombre    String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("core_pais")
}

/// Catálogo transversal de motivos (la razón de una operación), discriminado por
/// `modulo` para que cada módulo tenga su propio juego. Hoy lo usa Devoluciones
/// (motivo obligatorio al crear). `requiereObservacion` marca el motivo que exige
/// cargar una observación (caso "Otro"). Los módulos lo referencian por ID.
model Motivo {
  id                  Int      @id @default(autoincrement())
  modulo              String   @db.VarChar(40)
  nombre              String   @db.VarChar(120)
  requiereObservacion Boolean  @default(false) @map("requiere_observacion")
  activo              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([modulo, activo])
  @@map("core_motivo")
}

model Deposito {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(150)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("core_deposito")
}

model Usuario {
  id               Int       @id @default(autoincrement())
  username         String    @unique @db.VarChar(60)
  email            String?   @unique @db.VarChar(150)
  nombre           String    @db.VarChar(150)
  claveHash        String    @map("clave_hash") @db.VarChar(255)
  activo           Boolean   @default(true)
  primerIngreso    Boolean   @default(true) @map("primer_ingreso")
  intentosFallidos Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime? @map("bloqueado_hasta")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  roles UsuarioRol[]

  @@index([nombre])
  @@map("core_usuario")
}

model Rol {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar(60)
  descripcion String? @db.VarChar(255)
  activo      Boolean @default(true)

  permisos RolPermiso[]
  usuarios UsuarioRol[]

  @@map("core_rol")
}

model Permiso {
  id          Int     @id @default(autoincrement())
  codigo      String  @unique @db.VarChar(60)
  descripcion String? @db.VarChar(255)

  roles RolPermiso[]

  @@map("core_permiso")
}

model RolPermiso {
  rolId     Int @map("rol_id")
  permisoId Int @map("permiso_id")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("core_rol_permiso")
}

model UsuarioRol {
  usuarioId Int @map("usuario_id")
  rolId     Int @map("rol_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("core_usuario_rol")
}

model Cliente {
  id               Int       @id @default(autoincrement())
  nroCliente       String    @unique @map("nro_cliente") @db.VarChar(40)
  nombre           String    @db.VarChar(200)
  direccion        String?   @db.VarChar(300)
  // Correo(s) de contacto del cliente. Admite varios separados por coma.
  // Lo usan las notificaciones por email cuando una regla marca "incluir cliente".
  email            String?   @db.VarChar(255)
  claveHash        String    @map("clave_hash") @db.VarChar(255)
  primerIngreso    Boolean   @default(true) @map("primer_ingreso")
  activo           Boolean   @default(true)
  paisId           Int?      @map("pais_id")
  depositoId       Int?      @map("deposito_id")
  intentosFallidos Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime? @map("bloqueado_hasta")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([nombre])
  @@map("core_cliente")
}

model Producto {
  id            Int      @id @default(autoincrement())
  codigoInterno String   @unique @map("codigo_interno") @db.VarChar(60)
  titulo        String   @db.VarChar(300)
  editorial     String?  @db.VarChar(200)
  autor         String?  @db.VarChar(200)
  // Portada del libro: ruta pública servida bajo /uploads (WebP comprimido).
  imagenUrl     String?  @map("imagen_url") @db.VarChar(300)
  // Unidad base = libro. equivCaja = unidades por caja; equivPallet = cajas por pallet.
  unidadBase    String   @default("unidad") @map("unidad_base") @db.VarChar(20)
  equivCaja     Int      @default(1) @map("equiv_caja")
  equivPallet   Int      @default(1) @map("equiv_pallet")
  // Lote/serie: reservado, desactivado por defecto (no migrar tablas a futuro).
  loteHabilitado Boolean @default(false) @map("lote_habilitado")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  isbns ProductoIsbn[]

  // Búsqueda del catálogo: FULLTEXT para MATCH por palabra del título y B-tree
  // para el orderBy titulo (evita filesort en el listado paginado). map:
  // explícito para que los dos índices sobre `titulo` no choquen de nombre.
  @@fulltext([titulo], map: "core_producto_titulo_ft")
  @@index([titulo], map: "core_producto_titulo_idx")
  @@map("core_producto")
}

model ProductoIsbn {
  id         Int    @id @default(autoincrement())
  productoId Int    @map("producto_id")
  isbn       String @unique @db.VarChar(20)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@map("core_producto_isbn")
}

model Transportista {
  id       Int     @id @default(autoincrement())
  nombre   String  @db.VarChar(200)
  contacto String? @db.VarChar(200)
  activo   Boolean @default(true)

  @@map("core_transportista")
}

/// Auditoría inmutable: solo se inserta, nunca se edita (sin updatedAt).
/// Las referencias van por ID (sin FK) para que el log sobreviva a cambios.
model Auditoria {
  id             BigInt   @id @default(autoincrement())
  actorId        Int?     @map("actor_id")
  actorTipo      String   @map("actor_tipo") @db.VarChar(20) // usuario | cliente | sistema
  accion         String   @db.VarChar(60)
  entidad        String   @db.VarChar(60)
  entidadId      String   @map("entidad_id") @db.VarChar(60)
  estadoAnterior String?  @map("estado_anterior") @db.VarChar(60)
  estadoNuevo    String?  @map("estado_nuevo") @db.VarChar(60)
  detalle        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([entidad, entidadId])
  @@map("core_auditoria")
}

// ---------------------------------------------------------------------------
//  NOTIFICACIONES (core) — emails por cambio de estado. Transversal (`modulo`):
//  hoy lo usa Devoluciones, pero el motor sirve a futuros módulos sin tocar nada.
//  Se engancha por EVENTO de dominio (devolucion.estado_cambiado): no acopla a
//  internos de Devoluciones. Referencias a entidades de otros módulos por ID
//  suelto (entidad_id), sin FK cruzada.
// ---------------------------------------------------------------------------

/// Grupo reutilizable de destinatarios. `emails` = lista separada por coma,
/// punto y coma o salto de línea; se parsea y deduplica al enviar.
model GrupoCorreo {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(120)
  emails    String   @db.Text
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reglas NotificacionReglaGrupo[]

  @@map("core_grupo_correo")
}

/// Regla de notificación por estado destino. Una por (modulo, estado). Dispara
/// hacia varios grupos y/o usuarios internos, y opcionalmente al cliente de la
/// entidad (incluirCliente). asunto/cuerpo son plantillas con placeholders
/// ({{nro}}, {{cliente}}, {{estado}}, {{estadoAnterior}}, {{fecha}}).
model NotificacionRegla {
  id             Int      @id @default(autoincrement())
  modulo         String   @default("devoluciones") @db.VarChar(40)
  estado         String   @db.VarChar(60)
  incluirCliente Boolean  @default(false) @map("incluir_cliente")
  asunto         String   @db.VarChar(255)
  cuerpo         String   @db.Text
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  grupos   NotificacionReglaGrupo[]
  usuarios NotificacionReglaUsuario[]

  @@unique([modulo, estado])
  @@map("core_notificacion_regla")
}

/// Destinos "grupo" de una regla (N:N regla↔grupo).
model NotificacionReglaGrupo {
  reglaId Int @map("regla_id")
  grupoId Int @map("grupo_id")

  regla NotificacionRegla @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  grupo GrupoCorreo       @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@id([reglaId, grupoId])
  @@index([grupoId])
  @@map("core_notificacion_regla_grupo")
}

/// Destinos "usuario interno" de una regla. usuarioId es referencia suelta a
/// core_usuario (sin FK ni back-relation, para no tocar el modelo Usuario): el
/// email se resuelve en código al enviar, filtrando usuarios inexistentes.
model NotificacionReglaUsuario {
  reglaId   Int @map("regla_id")
  usuarioId Int @map("usuario_id")

  regla NotificacionRegla @relation(fields: [reglaId], references: [id], onDelete: Cascade)

  @@id([reglaId, usuarioId])
  @@index([usuarioId])
  @@map("core_notificacion_regla_usuario")
}

/// Log / outbox de envíos. estadoEnvio: PENDIENTE | ENVIADO | ERROR. El cron de
/// reintento reprocesa PENDIENTE/ERROR con intentos < tope. entidadId guarda el
/// ID de la entidad del módulo (p.ej. la autorización) sin FK cruzada.
model NotificacionLog {
  id            Int       @id @default(autoincrement())
  reglaId       Int?      @map("regla_id")
  modulo        String    @db.VarChar(40)
  entidadId     Int       @map("entidad_id")
  estado        String    @db.VarChar(60)
  destinatarios String    @db.Text
  asunto        String    @db.VarChar(255)
  cuerpo        String    @db.Text
  estadoEnvio   String    @default("PENDIENTE") @map("estado_envio") @db.VarChar(20)
  error         String?   @db.Text
  intentos      Int       @default(0)
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([estadoEnvio])
  @@index([modulo, entidadId])
  @@map("core_notificacion_log")
}

/// Esqueleto: health check. Se mantiene; el endpoint /api/health usa SELECT 1.
model HealthCheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  @@map("core_health_check")
}

// ===========================================================================
//  DEVOLUCIONES (dev_*) — Módulo 1
//  Cross-núcleo (cliente/usuario/producto/transportista/depósito) y ubicaciones
//  se guardan por ID/código SIN FK dura.
// ===========================================================================

enum DevEstado {
  A_APROBAR
  APROBADO
  EN_TRANSITO
  ENTREGADO
  INGRESO_DEPOSITO
  PROCESADO
}

enum DevEstadoControl {
  NO_CONTROLADO
  EN_CONTROL
  CONTROLADO
}

enum DevActorTipo {
  usuario
  cliente
}

model DevAutorizacion {
  id            Int       @id @default(autoincrement())
  estado        DevEstado @default(A_APROBAR)
  // Referencias al núcleo por ID (sin FK): se resuelven por servicio.
  clienteId     Int       @map("cliente_id")
  depositoId    Int       @map("deposito_id")
  creadoPorId   Int          @map("creado_por_id")
  creadoPorTipo DevActorTipo @map("creado_por_tipo")
  transportistaId Int?    @map("transportista_id")

  // Motivo de la devolución (obligatorio al crear; ver core_motivo). Nullable en
  // DB por las filas históricas previas a esta función; el servicio lo exige al
  // crear. Referencia al catálogo transversal por ID, sin FK cruzada.
  motivoId         Int? @map("motivo_id")
  // Cantidad de unidades (libros) a devolver, declarada al crear. Obligatoria en
  // el servicio; nullable en DB por las filas históricas.
  cantidadUnidades Int? @map("cantidad_unidades")

  // Declarado por el cliente
  bultosDeclarados   Int?     @map("bultos_declarados")
  pesoTotalDeclarado Decimal? @map("peso_total_declarado") @db.Decimal(10, 3)

  // Registrado en depósito
  bultosRecibidos Int? @map("bultos_recibidos")

  // Lote de devolución del ERP (Fierro) contra el que se reconcilia. Se puede
  // asignar antes del cierre (para la validación periódica) y es obligatorio para
  // Procesar. Referencia por código a dev_lote (mismo módulo); no FK.
  loteCodigo            String? @map("lote_codigo") @db.VarChar(60)
  // Firma (hash) de la última reconciliación notificada por el chequeo periódico
  // de lotes: evita re-mandar el mail salvo que la comparación cambie.
  loteValidacionFirma   String? @map("lote_validacion_firma") @db.VarChar(64)

  // Ubicaciones: CÓDIGO string, validado por UbicacionResolverPort (NO FK).
  ubicacionEspera       String? @map("ubicacion_espera") @db.VarChar(60)
  ubicacionDestinoBueno String? @map("ubicacion_destino_bueno") @db.VarChar(60)
  ubicacionDestinoMalo  String? @map("ubicacion_destino_malo") @db.VarChar(60)

  observaciones String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  declaraciones DevDeclaracion[]
  bultos        DevBulto[]
  excepciones   DevExcepcionConsignacion[]

  @@index([estado])
  @@index([clienteId])
  @@index([createdAt])
  @@map("dev_autorizacion")
}

/// Líneas declaradas por el cliente (lo que devuelve por título).
model DevDeclaracion {
  id             Int    @id @default(autoincrement())
  autorizacionId Int    @map("autorizacion_id")
  // ISBN escaneado + producto resuelto (por código interno, sin FK al núcleo).
  isbn           String @db.VarChar(20)
  productoId     Int?   @map("producto_id")
  cantidad       Int

  autorizacion DevAutorizacion @relation(fields: [autorizacionId], references: [id], onDelete: Cascade)

  @@index([autorizacionId])
  @@map("dev_declaracion")
}

/// Bulto físico: el cliente declara cantidad; depósito pesa cada uno.
model DevBulto {
  id             Int              @id @default(autoincrement())
  autorizacionId Int              @map("autorizacion_id")
  numero         Int
  peso           Decimal?         @db.Decimal(10, 3)
  estadoControl  DevEstadoControl @default(NO_CONTROLADO) @map("estado_control")

  autorizacion DevAutorizacion @relation(fields: [autorizacionId], references: [id], onDelete: Cascade)
  controles    DevControl[]

  @@unique([autorizacionId, numero])
  @@index([autorizacionId])
  @@map("dev_bulto")
}

/// Control por bulto y por ISBN: cantidad total y cuántas en mal estado
/// (bueno = cantidad - malEstado). Reconciliación agrega por ISBN.
model DevControl {
  id         Int    @id @default(autoincrement())
  bultoId    Int    @map("bulto_id")
  isbn       String @db.VarChar(20)
  productoId Int?   @map("producto_id")
  cantidad   Int
  malEstado  Int    @default(0) @map("mal_estado")

  bulto DevBulto @relation(fields: [bultoId], references: [id], onDelete: Cascade)

  @@index([bultoId])
  @@map("dev_control")
}

/// Saldo en consignación por cliente + ISBN, importado del ERP por el
/// integrador (vía Integraciones → ConsignacionPort). Insumo de la
/// reconciliación: cuánto tiene el cliente "en depósito" sin comprar. NO
/// bloquea; si una devolución lo excede, se exige observación.
/// Referencias al núcleo por ID (sin FK cruzada), como DevAutorizacion.
/// Semántica snapshot: full-replace por cliente en cada carga (idempotente);
/// snapshotTs descarta cargas que llegan fuera de orden.
model DevConsignacionSaldo {
  id         Int      @id @default(autoincrement())
  clienteId  Int      @map("cliente_id")
  isbn       String   @db.VarChar(20)
  productoId Int?     @map("producto_id")
  cantidad   Int
  snapshotTs DateTime @map("snapshot_ts")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([clienteId, isbn], name: "cliente_isbn")
  @@index([clienteId])
  @@index([isbn])
  @@map("dev_consignacion_saldo")
}

enum DevExcepcionEstado {
  PENDIENTE
  APROBADA
  RECHAZADA
}

/// Excepción de consignación: autoriza declarar `cantidad` unidades de un ISBN
/// en UNA devolución, por fuera de lo que el cliente tiene en consignación
/// (libro ausente de la lista o por encima del saldo). La solicita el cliente
/// (o quien declara) y la aprueba/rechaza un usuario con permiso
/// `devolucion.autorizar_excepcion` (Gerencia). Alcance: solo esa autorización.
/// Lo permitido a declarar por ISBN = saldo consignación + Σ excepciones APROBADAS.
model DevExcepcionConsignacion {
  id             Int                @id @default(autoincrement())
  autorizacionId Int                @map("autorizacion_id")
  isbn           String             @db.VarChar(20)
  productoId     Int?               @map("producto_id")
  cantidad       Int // unidades autorizadas por fuera de la consignación
  estado         DevExcepcionEstado @default(PENDIENTE)
  // Quién solicita (cliente o usuario interno que arma la devolución).
  solicitadoPorId   Int          @map("solicitado_por_id")
  solicitadoPorTipo DevActorTipo @map("solicitado_por_tipo")
  motivoSolicitud   String?      @map("motivo_solicitud") @db.Text
  // Resolución: usuario con permiso (Gerencia). Null mientras está PENDIENTE.
  resueltoPorId   Int?      @map("resuelto_por_id")
  resueltoEn      DateTime? @map("resuelto_en")
  motivoResolucion String?  @map("motivo_resolucion") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  autorizacion DevAutorizacion @relation(fields: [autorizacionId], references: [id], onDelete: Cascade)

  @@index([autorizacionId])
  @@index([estado])
  @@map("dev_excepcion_consignacion")
}

/// Lote de devolución importado del ERP (Fierro) por el integrador, vía
/// DevolucionesLotePort. Es el dato "oficial" contra el que la reconciliación
/// compara lo declarado por el cliente en el WMS. Identidad por `codigo`
/// (= return_lot.document_id de Fierro): idempotente, upsert por codigo que
/// reemplaza los renglones. Referencias al núcleo por código (sin FK cruzada).
/// Las fechas se guardan TAL CUAL las manda Fierro (string), para no transformar
/// input externo ni introducir ambigüedad de zona horaria.
model DevLote {
  id                 Int      @id @default(autoincrement())
  codigo             String   @unique @db.VarChar(60)
  numero             String?  @db.VarChar(60)
  fecha              String?  @db.VarChar(40)
  nroCliente         String   @map("nro_cliente") @db.VarChar(40)
  clienteNombre      String?  @map("cliente_nombre") @db.VarChar(200)
  deposito           String?  @db.VarChar(150)
  estado             String?  @db.VarChar(60)
  motivo             String?  @db.VarChar(200)
  remitoCliente      String?  @map("remito_cliente") @db.VarChar(60)
  fechaRemitoCliente String?  @map("fecha_remito_cliente") @db.VarChar(40)
  totalItems         Int?     @map("total_items")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  items DevLoteItem[]

  @@index([nroCliente])
  @@map("dev_lote")
}

/// Renglón de un lote de devolución de Fierro. `cantidad` es lo que el ERP
/// espera; cantidadCliente/cantidadRechazada vienen del ERP para detalle. Se
/// reemplazan por completo en cada upsert del lote.
model DevLoteItem {
  id                Int     @id @default(autoincrement())
  loteId            Int     @map("lote_id")
  isbn              String  @db.VarChar(20)
  cantidad          Int
  cantidadCliente   Int?    @map("cantidad_cliente")
  cantidadRechazada Int?    @map("cantidad_rechazada")
  titulo            String? @db.VarChar(300)
  intCode           String? @map("int_code") @db.VarChar(60)

  lote DevLote @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@unique([loteId, isbn])
  @@index([loteId])
  @@map("dev_lote_item")
}
