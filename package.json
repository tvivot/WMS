{
  "name": "wms-grupal",
  "version": "0.1.0",
  "private": true,
  "description": "WMS Grupal — monolito modular (NestJS + React PWA). Deployable único.",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w @wms/shared",
    "build:web": "npm run build -w @wms/web",
    "copy:web": "node scripts/copy-web.mjs",
    "build:api": "npm run build -w @wms/api",
    "build": "npm run build:shared && npm run build:web && npm run copy:web && npm run build:api",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "migrate": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "start": "node apps/api/dist/main.js",
    "dev:api": "npm run start:dev -w @wms/api",
    "dev:web": "npm run dev -w @wms/web"
  }
}
