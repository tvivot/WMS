# Copiar a .env (NUNCA commitear el .env real).
# Base de datos MySQL/MariaDB (Hostinger). NO PostgreSQL.
# IMPORTANTE (Hostinger): agregar connection_limit. El engine "binary" de Prisma
# abre por defecto (cores_físicos * 2 + 1) conexiones; en un nodo de muchos cores
# eso son decenas de conexiones/threads y Hostinger cuenta threads como procesos
# (límite nproc → "se dispara a +120 procesos"). connection_limit=5 lo acota.
DATABASE_URL="mysql://user:password@host:3306/dbname?connect_timeout=15&connection_limit=5"

# Tuning de threads nativos para hosting compartido (cuenta threads como procesos):
#   VIPS_CONCURRENCY=1   → pool de libvips/sharp (además del cap en código)
#   UV_THREADPOOL_SIZE=4 → pool de libuv (fs/crypto/scrypt); default 4
# VIPS_CONCURRENCY=1
# UV_THREADPOOL_SIZE=4

# Secreto para firmar JWT (string random largo).
JWT_SECRET="change-me-please"

# Puerto. En Hostinger lo inyecta el entorno; localmente 3000.
PORT=3000

# Origen permitido para CORS en producción (opcional; en dev se permite todo).
# CORS_ORIGIN=https://tu-dominio

# Conector WooCommerce (Integraciones): completa la portada de los productos
# con la URL de la imagen hosteada en WooCommerce, matcheando por SKU = ISBN.
# Si falta cualquiera de las tres, el conector queda INERTE (no hace nada).
# WOO_URL=https://tu-tienda.com
# WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxx
# WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxx

# Carpeta donde se guardan las portadas subidas (servidas bajo /uploads).
# Por defecto se usa una carpeta "Tapas" a la misma altura que public_html
# (en Hostinger: /home/uXXXX/domains/<dominio>/Tapas), fuera del build (dist/)
# para sobrevivir a los redeploys. Para forzar otra ruta absoluta, descomentar:
# UPLOADS_DIR=/home/uXXXX/domains/<dominio>/Tapas
