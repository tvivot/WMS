# Copiar a .env (NUNCA commitear el .env real).
# Base de datos MySQL/MariaDB (Hostinger). NO PostgreSQL.
DATABASE_URL="mysql://user:password@host:3306/dbname"

# Secreto para firmar JWT (string random largo).
JWT_SECRET="change-me-please"

# Puerto. En Hostinger lo inyecta el entorno; localmente 3000.
PORT=3000

# Origen permitido para CORS en producción (opcional; en dev se permite todo).
# CORS_ORIGIN=https://tu-dominio
